<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/fondoPastel"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:text="📅 Entrevistas"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/amarilloOscuro"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="12dp"/>

    <CalendarView
        android:id="@+id/calendarViewEntrevistas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/blanco"
        android:elevation="2dp"/>

    <Button
        android:id="@+id/btnHoy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="➕ Hoy"
        android:layout_gravity="end"
        android:layout_marginTop="8dp"
        android:backgroundTint="@color/naranjaOscuro"
        android:textColor="@android:color/white"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/txtProximaEntrevista"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/amarilloPastel"
        android:padding="12dp"
        android:textColor="@android:color/black"
        android:text="Próxima Entrevista: Sin entrevistas pactadas"
        android:layout_marginTop="12dp"
        android:background="@drawable/borde_amarillo"/>

    <Button
        android:id="@+id/btnProximasEntrevistas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📆 Ver Próximas Entrevistas"
        android:layout_marginTop="12dp"
        android:backgroundTint="@color/amarilloOscuro"
        android:textColor="@android:color/white"
        android:textStyle="bold"/>

    <Button
        android:id="@+id/btnEntrevistasRealizadas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="✔️ Entrevistas Realizadas"
        android:layout_marginTop="8dp"
        android:backgroundTint="@color/amarilloOscuro"
        android:textColor="@android:color/white"
        android:textStyle="bold"/>

</LinearLayout>


