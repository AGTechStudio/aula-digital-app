<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#FFF9E5">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Editar Año"
        android:textColor="#BF8C2E"
        android:textStyle="bold"
        android:paddingBottom="8dp"/>

    <Spinner
        android:id="@+id/spinnerEditarAnio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/spinner_background"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Editar Mes"
        android:textColor="#BF8C2E"
        android:textStyle="bold"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"/>

    <Spinner
        android:id="@+id/spinnerEditarMes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/spinner_background"/>

    <Button
        android:id="@+id/btnReemplazarArchivo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Reemplazar archivo"
        android:textColor="#FFFFFF"
        android:backgroundTint="#F9A825"
        android:layout_marginTop="20dp"/>

</LinearLayout>
