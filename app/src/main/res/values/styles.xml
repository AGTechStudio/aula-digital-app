<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="BotonMenu">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:backgroundTint">@color/amarilloPastel</item>
        <item name="android:textColor">@color/textoPrincipal</item>
        <item name="android:layout_marginBottom">12dp</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="TextoDetalle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#FF9800</item> <!-- Naranja -->
        <item name="android:textSize">16sp</item>
        <item name="android:layout_marginTop">8dp</item>
    </style>

    <!-- Estilo para los valores mostrados -->
    <style name="ValorDetalle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">#000000</item> <!-- Negro -->
        <item name="android:background">@drawable/borde_edittext</item>
        <item name="android:padding">8dp</item>
    </style>
</resources>